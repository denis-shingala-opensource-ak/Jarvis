# === LLM Configuration ===
LLM_PROVIDER=your-ollama-provider-here
LLM_HOST=your-ollama-host-url-here
LLM_MODEL=your-ollama-llm-model-name-here

# === Speech Configuration ===
# Options: google_free (no key needed) | openai_whisper
STT_PROVIDER=google_free
# Options: google_free (no key needed) | openai_tts
TTS_PROVIDER=google_free
# Options: alloy | echo | fable | onyx | nova | shimmer
TTS_VOICE=onyx
# === App Configuration ===
APP_NAME=your-app-name-here
HOST=your-app-host-name-here
PORT=your-app-port-here
DEBUG=true
SECRET_KEY=your-secret-key-here

# === Database ===
DATABASE_URL=mysql+pymysql://username:password@hostname/jarvis

# === JWT Configuration ===
JWT_ALGORITHM=jwt-algorithm-here
JWT_SECRET_KEY=jwt-secret-key-here